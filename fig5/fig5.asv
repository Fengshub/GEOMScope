%% 10/21
close all
for idx=5:12
    figure
    imagesc(imgaussfilt(recon_rec4(:,:,idx),2))
    daspect([1 1 1])
    axis off
    caxis([0 30])
end
%%
% maxi=max(recon_rec4(:));
close all
% recon3(:,:,5)=recon3(:,:,5)+recon3(:,:,4);
recon3=imgaussfilt(recon2,2);
maxi=max(recon3(:));
for idx=5:13
    if idx>=13
        temp=zeros(1024,1024);
    else
        temp=recon3(:,:,idx);%imgaussfilt(recon3(:,:,idx),2);
    end
    temp=temp/maxi;
    imwrite(temp,[num2str(idx),'.jpg'])
    figure
    imagesc(temp)
    daspect([1 1 1])
    axis off
%     colormap fire
    colormap parula
    caxis([0 1])
end