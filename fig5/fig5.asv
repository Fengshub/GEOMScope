% figure
% imagesc(recon)
% % imagesc(imgaussfilt(recon,2))
% axis off
% daspect([1 1 1])
%% 11/20
% recon_rec(isnan(recon_rec))=0;
% recon_rec3=recon_rec;
recon_rec=recon_rec3;
recon_rec(1:5,:,:)=0;recon_rec(:,1:5,:)=0;recon_rec(end-4:end,:,:)=0;recon_rec(:,end-4:end,:)=0;
recon_rec(recon_rec<1500)=0;
recon_rec=imgaussfilt(recon_rec,3);
% recon_rec=recon_rec3;
% recon_rec=imgaussfilt(recon_rec,3);
% CCmap=zeros(size(recon_rec));
% for idx=1:size(recon_rec,3)
%     CCidx=bwconncomp(recon_rec(:,:,idx));
%     temp=CCmap(:,:,idx);
%     for cidx=1:CCidx.NumObjects
%         temp(CCidx.PixelIdxList{cidx})=1;
%     end
%     CCmap(:,:,idx)=temp;

CC = bwconncomp(recon_rec,26);
% recon_rec2=zeros(size(recon_rec));
% for idx=1:CC.NumObjects
%     temp=CC.PixelIdxList{idx};
%     a=find(recon_rec==max(recon_rec(temp)));
%     recon_rec2(a)=recon_rec(a);
% end
recon_rec5=zeros(size(recon_rec));
recon=zeros(size(recon_rec,1),size(recon_rec,2));
recon2=zeros(size(recon_rec,1),size(recon_rec,2),size(recon_rec,3));
for th=0.05:0.05:0.8
    for idx=1:CC.NumObjects
        temp=CC.PixelIdxList{idx};
%         if length(temp)<10
%             recon_rec(temp)=0;
%         else
            recon_rec(temp)=recon_rec(temp)/max(recon_rec(temp));
%         end
    end
    recon_rec(recon_rec<th)=0;
    disp(th);
    CC = bwconncomp(recon_rec,26);
    recon_rec4=zeros(size(recon_rec));
    for idx=1:CC.NumObjects
        temp=CC.PixelIdxList{idx};
        recon_rec(temp)=recon_rec(temp)+rand(size(temp))*0.005;
        a=find(recon_rec==max(recon_rec(temp)));
%         if(a==562884)
%             bb=1;
%         end
        if length(temp)<10
            recon_rec4(a)=recon_rec3(a);
        else
            recon_rec4(a)=recon_rec3(a);%/(length(temp)/50).^0.3;
        end
%         recon_rec5(a)=recon_rec3(a)/(length(temp)/50).^0.3;
    end
    recon=recon+sum(recon_rec4(:,:,:),3);
    recon2=recon2+recon_rec4;
end
% recon=sum(recon_rec4(:,:,:),3);
recon=recon/max(recon(:));
figure
imagesc(imgaussfilt(recon,2))
axis off
daspect([1 1 1])
%%
recon3=sum(recon_rec3(:,:,:),3);
figure
imagesc(imgaussfilt(recon3,2))
axis off
%%
close all
for idx=1:12
    figure
    imagesc(imgaussfilt(recon_rec4(:,:,idx),5))
    daspect([1 1 1])
    axis off
end
%% 
close all
maxi=max(recon_rec3(:));
for idx=5:12
    figure
    temp=recon_rec3(:,:,idx);
    imagesc(recon_rec3(:,:,idx))
    daspect([1 1 1])
    axis off
%     colormap fire
end
